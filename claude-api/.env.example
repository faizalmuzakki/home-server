# Claude Code API Configuration
PORT=3100

# Primary auth is the Max subscription via OAuth — run `claude` (interactive
# login) once on the host. ANTHROPIC_API_KEY below is the fallback used
# automatically when the CLI returns 401/403 (e.g. OAuth token expired and
# not yet refreshed). Leave unset to disable the fallback.
ANTHROPIC_API_KEY=

# API authentication - clients must send this as Bearer token
API_SECRET=change-me-to-a-secure-random-string

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=*

# Claude Code settings
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TURNS=10
MAX_CONCURRENT=3
