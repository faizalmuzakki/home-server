# Claude Code API Configuration
PORT=3100

# No ANTHROPIC_API_KEY needed — uses Max subscription via OAuth
# Claude Code must be logged in on the host: claude (interactive login once)

# API authentication - clients must send this as Bearer token
API_SECRET=change-me-to-a-secure-random-string

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=*

# Claude Code settings
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TURNS=10
MAX_CONCURRENT=3
