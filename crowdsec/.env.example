# CrowdSec Configuration
# Copy to .env and configure

# Path to home-server repo on host (used to mount Traefik logs)
HOME_SERVER_PATH=/home/solork/Projects/home-server


# Optional: Enroll in CrowdSec Console for centralized management
# Get key from: https://app.crowdsec.net/
# CROWDSEC_ENROLL_KEY=your-enrollment-key

# Bouncer API Key (generate after first start)
# Run: docker exec crowdsec cscli bouncers add traefik-bouncer
# Then copy the API key here
CROWDSEC_BOUNCER_API_KEY=
