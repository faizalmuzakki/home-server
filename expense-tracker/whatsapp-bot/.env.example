# API URL (use docker service name in Docker, localhost for local dev)
API_URL=http://api:3000

# =============================================
# SECURITY: ALLOWED_NUMBERS (REQUIRED!)
# =============================================
# Comma-separated list of allowed phone numbers
# Format: country code + number without + sign
# Example: 6281234567890,6289876543210
#
# WARNING: The bot will NOT start if this is empty!
# This is a security feature to prevent unauthorized access.
ALLOWED_NUMBERS=

# Dashboard PIN (for /pin command)
DASHBOARD_PIN=123456

# =============================================
# Q&A FEATURE: Answer questions in WhatsApp groups
# =============================================
# Claude API (self-hosted service using Max subscription)
CLAUDE_API_URL=http://claude-api:3100
CLAUDE_API_SECRET=your_claude_api_secret_here

# Comma-separated WhatsApp group JIDs allowed for Q&A
# Format: group_id@g.us (check bot logs for group JIDs)
# Example: 120363012345678901@g.us,120363098765432109@g.us
ALLOWED_GROUPS=

# Notes:
# - Polls, giveaways, trivia, todos, notes, birthdays, AFK, autoresponders,
#   welcomer, and confessions store data locally in ./data/bot.db
# - Confession setup expects a WhatsApp group JID as the target

# =============================================
# DISCORD ALERTING (optional)
# =============================================
# Webhook URL for error notifications from the expense API interceptor.
# Fires on 5xx / network / timeout (never on 4xx user errors).
# If unset or empty, Discord alerts are silently disabled.
DISCORD_WEBHOOK_URL=
