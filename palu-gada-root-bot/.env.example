# Root Dev Token (Required)
# Get this from the Root Developer Portal
DEV_TOKEN=your_dev_token_here

# Anthropic API Key (Required if using AI features)
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Admin user ID — gates warn/kick/ban/toproles/timeout commands
# Leave blank to disable all moderation commands (safest default)
ADMIN_USER_ID=

# Domain (used by Traefik health endpoint label)
DOMAIN=solork.dev

# Starboard threshold (optional, default 3)
STARBOARD_THRESHOLD=3
