# Root Dev Token (Required)
# Get this from the Root Developer Portal
DEV_TOKEN=your_dev_token_here

# Claude API (self-hosted service using Max subscription)
CLAUDE_API_URL=http://claude-api:3100
CLAUDE_API_SECRET=your_claude_api_secret_here

# Admin user ID — gates warn/kick/ban/toproles/timeout commands
# Leave blank to disable all moderation commands (safest default)
ADMIN_USER_ID=

# Additional comma-separated admin user IDs (optional, adds to ADMIN_USER_ID)
# Any user in either var can run /server and other admin-gated commands.
# ALLOWED_ADMIN_USERS=uuid1,uuid2

# Domain (used by Traefik health endpoint label)
DOMAIN=solork.dev

# Starboard threshold (optional, default 3)
STARBOARD_THRESHOLD=3
