# Backup script configuration (source'd by backup-encrypted.sh)
# Copy to .env.backup and fill in values.

# Discord webhook for success/failure notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# rclone remote for offsite sync (optional)
# Format: <remote-name>:<bucket-or-path>
# RCLONE_REMOTE=r2:home-server-backups
